__pycache__/
*.pyc
backend/uploads/
backend/app_data.db
*.db
.env
*.env
.env.*
!.env.example

# Local benchmark databases + profiler outputs: never commit data/outputs,
# but keep the folder structure via .gitkeep files.
backend/local_benchmarks/relational_sample_dbs/raw/*
backend/local_benchmarks/relational_sample_dbs/sqlite/*
backend/local_benchmarks/relational_sample_dbs/metadata/*
backend/local_benchmarks/relational_sample_dbs/reports/*
!backend/local_benchmarks/relational_sample_dbs/raw/.gitkeep
!backend/local_benchmarks/relational_sample_dbs/sqlite/.gitkeep
!backend/local_benchmarks/relational_sample_dbs/metadata/.gitkeep
!backend/local_benchmarks/relational_sample_dbs/reports/.gitkeep